    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.2",
    "react-scripts": "^5.0.1",
    "recharts": "^3.6.0",
    "web-vitals": "^2.1.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.2",
